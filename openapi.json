{
  "openapi": "3.1.0",
  "info": {
    "title": "UA Parser for AI Agents",
    "version": "1.0.0",
    "description": "2ms user-agent parsing with AI bot detection. 1000/day free."
  },
  "servers": [{"url": "https://api.uaparser.dev"}],
  "paths": {
    "/v1/parse": {
      "get": {
        "summary": "Parse User-Agent + Detect AI Crawlers",
        "operationId": "parseUserAgent",
        "parameters": [
          {"name": "key", "in": "query", "required": true, "schema": {"type": "string", "example": "test_123"}},
          {"name": "ua", "in": "query", "required": true, "schema": {"type": "string", "example": "Mozilla/5.0..."}}
        ],
        "responses": {
          "200": {
            "description": "Parsed UA",
            "content": {"application/json": {"schema": {"type": "object"}}}
          }
        }
      }
    }
  }
}
